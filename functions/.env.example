# Ejemplo de variables de entorno para Cloud Functions
# Copia este archivo a .env y completa con tus datos reales

RUC_EMPRESA=9999999999999
RAZON_SOCIAL=NOMBRE DE TU EMPRESA
NOMBRE_COMERCIAL=NOMBRE COMERCIAL
DIRECCION_MATRIZ=Dirección completa de tu empresa
OBLIGADO_CONTABILIDAD=NO
CONTRIBUYENTE_ESPECIAL=000

# El password del certificado se configura como secret (ver README)
# CERTIFICADO_PASSWORD=tu_password_aqui

